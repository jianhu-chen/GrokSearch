# ===== Grok API（必填）=====
GROK_API_URL=https://api.x.ai/v1
GROK_API_KEY=your-grok-api-key

# ===== MCP 服务配置 =====
MCP_TRANSPORT=http

# 用户认证 Token（逗号分隔，为空则不启用认证）
MCP_AUTH_TOKENS=
# 或从文件加载 Token（每行一个）
# MCP_AUTH_TOKENS_FILE=

# ===== Grok 模型 =====
# GROK_MODEL=grok-4-fast
# 是否允许通过 MCP 工具切换模型（云端部署建议设为 false）
# ENABLE_SWITCH_MODEL=false

# ===== Tavily（可选，用于 web_fetch / web_map）=====
# TAVILY_API_KEY=
# TAVILY_API_URL=https://api.tavily.com
# TAVILY_ENABLED=true

# ===== Firecrawl（可选，Tavily 失败时托底）=====
# FIRECRAWL_API_KEY=
# FIRECRAWL_API_URL=https://api.firecrawl.dev/v2

# ===== 重试策略 =====
# GROK_RETRY_MAX_ATTEMPTS=3
# GROK_RETRY_MULTIPLIER=1
# GROK_RETRY_MAX_WAIT=10

# ===== 日志 =====
# GROK_DEBUG=false
# GROK_LOG_LEVEL=INFO
GROK_LOG_DIR=/app/logs
